# ── Public — safe to expose in the browser ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# ── Server-only secrets — NEVER prefix these with NEXT_PUBLIC ─────────
# Supabase service-role key (Dashboard → Settings → API → service_role).
# Bypasses Row Level Security. Used only by server-side API routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin panel login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose-a-strong-password

# Secret used to sign the admin session cookie (32+ random characters)
ADMIN_SESSION_SECRET=generate-a-long-random-string

# NOTE: NEXT_PUBLIC_SUPABASE_ANON_KEY is no longer required — the browser
# never calls Supabase directly anymore.
